-- NEXUS ECOSYSTEM SCHEMA (Master Plan V2)

-- 1. ORGANIZATIONS (Multi-Tenant B2B Architecture)
CREATE TABLE public.organizations (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name TEXT NOT NULL,
  type TEXT NOT NULL, -- 'venue', 'studio', 'restaurant', 'planner', 'corporate'
  subscription_tier TEXT DEFAULT 'free',
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 2. ORGANIZATION MEMBERS (Many-to-Many mapping for users to businesses)
CREATE TABLE public.organization_members (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  role TEXT NOT NULL DEFAULT 'member', -- 'owner', 'admin', 'member'
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  UNIQUE(organization_id, user_id)
);

-- 3. ACTIVE MODULES (Odoo-Style Apps)
CREATE TABLE public.active_modules (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  module_name TEXT NOT NULL, -- e.g., 'venue_os', 'crm', 'displays', 'hall_management'
  is_active BOOLEAN DEFAULT true,
  activated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  UNIQUE(organization_id, module_name)
);

-- 4. EVENTS (The Universal Anchor)
CREATE TABLE public.events (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  customer_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE, -- The B2C user who created it
  name TEXT NOT NULL,
  event_type TEXT NOT NULL, -- 'wedding', 'birthday', 'corporate', etc.
  start_date TIMESTAMP WITH TIME ZONE,
  end_date TIMESTAMP WITH TIME ZONE,
  status TEXT DEFAULT 'draft', -- 'draft', 'published', 'completed', 'cancelled'
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Note: All future tables (invitations, memories, displays, budgets, etc.) 
-- will have an `event_id` column referencing public.events(id).
-- Business operations (vendor bookings) will link `event_id` to `organization_id`.

-- ==========================================
-- STUDIO OS MODULE
-- ==========================================

-- 5. STUDIO PROFILES
CREATE TABLE public.studio_profiles (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  branding_colors JSONB,
  portfolio_link TEXT,
  established_year INTEGER,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  UNIQUE(organization_id)
);

-- 6. STUDIO TEAM
CREATE TABLE public.studio_team (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  user_id UUID REFERENCES auth.users(id) ON DELETE SET NULL, -- Optional, if they have an account
  name TEXT NOT NULL,
  role TEXT NOT NULL, -- 'photographer', 'videographer', 'editor', etc.
  phone TEXT,
  is_freelancer BOOLEAN DEFAULT false,
  day_rate DECIMAL(10,2),
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 7. STUDIO EQUIPMENT
CREATE TABLE public.studio_equipment (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  name TEXT NOT NULL,
  category TEXT NOT NULL, -- 'camera', 'lens', 'drone', 'audio', 'lighting'
  serial_number TEXT,
  status TEXT DEFAULT 'available', -- 'available', 'in_use', 'maintenance'
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 8. STUDIO LEADS (CRM)
CREATE TABLE public.studio_leads (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  customer_name TEXT NOT NULL,
  customer_phone TEXT,
  event_date DATE,
  event_type TEXT,
  status TEXT DEFAULT 'new', -- 'new', 'contacted', 'meeting_scheduled', 'quoted', 'won', 'lost'
  budget_estimate DECIMAL(12,2),
  notes TEXT,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 9. STUDIO PROJECTS
CREATE TABLE public.studio_projects (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  lead_id UUID REFERENCES public.studio_leads(id) ON DELETE SET NULL,
  event_id UUID REFERENCES public.events(id) ON DELETE SET NULL, -- If linked to an ecosystem event
  name TEXT NOT NULL,
  status TEXT DEFAULT 'planning', -- 'planning', 'shooting', 'editing', 'review', 'delivered', 'completed'
  progress INTEGER DEFAULT 0,
  total_amount DECIMAL(12,2),
  paid_amount DECIMAL(12,2) DEFAULT 0,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 10. STUDIO QUOTES
CREATE TABLE public.studio_quotes (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  lead_id UUID REFERENCES public.studio_leads(id) ON DELETE CASCADE,
  package_name TEXT NOT NULL,
  total_amount DECIMAL(12,2) NOT NULL,
  status TEXT DEFAULT 'draft', -- 'draft', 'sent', 'accepted', 'rejected'
  valid_until DATE,
  items JSONB, -- Array of deliverables/services
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 11. STUDIO BOOKINGS
CREATE TABLE public.studio_bookings (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  quote_id UUID REFERENCES public.studio_quotes(id) ON DELETE RESTRICT,
  lead_id UUID REFERENCES public.studio_leads(id) ON DELETE CASCADE,
  event_date DATE NOT NULL,
  advance_payment DECIMAL(12,2) DEFAULT 0,
  status TEXT DEFAULT 'confirmed', -- 'confirmed', 'completed', 'cancelled'
  contract_url TEXT,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 12. STUDIO FINANCES
CREATE TABLE public.studio_finances (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  project_id UUID REFERENCES public.studio_projects(id) ON DELETE SET NULL,
  type TEXT NOT NULL, -- 'income', 'expense'
  category TEXT NOT NULL, -- 'booking', 'equipment_rental', 'freelancer_pay', 'marketing'
  amount DECIMAL(12,2) NOT NULL,
  payment_method TEXT,
  payment_date DATE NOT NULL,
  reference_number TEXT,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 13. STUDIO ALBUMS (Client Portals)
CREATE TABLE public.studio_albums (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id UUID NOT NULL REFERENCES public.organizations(id) ON DELETE CASCADE,
  project_id UUID REFERENCES public.studio_projects(id) ON DELETE CASCADE,
  title TEXT NOT NULL,
  cover_image_url TEXT,
  pin_code TEXT, -- Optional pin code for client access
  is_public BOOLEAN DEFAULT false,
  status TEXT DEFAULT 'draft', -- 'draft', 'published'
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 14. STUDIO ALBUM MEDIA
CREATE TABLE public.studio_album_media (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  album_id UUID NOT NULL REFERENCES public.studio_albums(id) ON DELETE CASCADE,
  media_url TEXT NOT NULL,
  media_type TEXT NOT NULL, -- 'image', 'video'
  category TEXT, -- 'highlights', 'baraat', 'mehndi'
  order_index INTEGER DEFAULT 0,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 15. RLS (Row Level Security) Base Setup
ALTER TABLE public.organizations ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.organization_members ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.active_modules ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.events ENABLE ROW LEVEL SECURITY;

ALTER TABLE public.studio_profiles ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_team ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_equipment ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_leads ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_projects ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_quotes ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_bookings ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_finances ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_albums ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.studio_album_media ENABLE ROW LEVEL SECURITY;

-- 6. TIMESTAMP TRIGGERS
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ language 'plpgsql';

CREATE TRIGGER update_organizations_updated_at
    BEFORE UPDATE ON public.organizations
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_events_updated_at
    BEFORE UPDATE ON public.events
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_profiles_updated_at
    BEFORE UPDATE ON public.studio_profiles
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_leads_updated_at
    BEFORE UPDATE ON public.studio_leads
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_projects_updated_at
    BEFORE UPDATE ON public.studio_projects
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_quotes_updated_at
    BEFORE UPDATE ON public.studio_quotes
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_bookings_updated_at
    BEFORE UPDATE ON public.studio_bookings
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_finances_updated_at
    BEFORE UPDATE ON public.studio_finances
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_studio_albums_updated_at
    BEFORE UPDATE ON public.studio_albums
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();